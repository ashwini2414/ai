#alpha-beta
def alpha_beta(depth, pos, max_turn, values, alpha, beta):
    if depth == 3:
        return values[pos]

    if max_turn:
        best = -100
        for i in range(2):
            value = alpha_beta(depth + 1, pos * 2 + i, False, values, alpha, beta)
            best = max(best, value)
            alpha = max(alpha, best)
            if beta <= alpha:
                break
        return best
    else:
        best = 100
        for i in range(2):
            value = alpha_beta(depth + 1, pos * 2 + i, True, values, alpha, beta)
            best = min(best, value)
            beta = min(beta, best)
            if beta <= alpha:
                break
        return best


values = []
print("Enter 8 leaf node values:")
for i in range(8):
    val = int(input(f"Value {i+1}: "))
    values.append(val)

result = alpha_beta(0, 0, True, values, -100, 100)
print("Best value is:", result)
